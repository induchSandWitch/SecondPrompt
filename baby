		rName.TextColor3 = TxtPri
		rName.TextSize = 11
		rName.TextXAlignment = Enum.TextXAlignment.Left
		rName.ZIndex = 602

		local rSub = Instance.new("TextLabel")
		rSub.Parent = resBtn
		rSub.BackgroundTransparency = 1
		rSub.Position = UDim2.new(0.6, 0, 0, 0)
		rSub.Size = UDim2.new(0.4, -8, 1, 0)
		rSub.Font = Enum.Font.Gotham
		rSub.Text = entry.tabName .. (entry.sectionName and (" › " .. entry.sectionName) or "")
		rSub.TextColor3 = TxtMut
		rSub.TextSize = 9
		rSub.TextXAlignment = Enum.TextXAlignment.Right
		rSub.ZIndex = 602

		resBtn.MouseEnter:Connect(function()
			Tween(resBtn, { BackgroundTransparency = 0, BackgroundColor3 = Color3.fromRGB(20, 20, 20) }, 0.1)
		end)

		resBtn.MouseLeave:Connect(function()
			Tween(resBtn, { BackgroundTransparency = 1 }, 0.1)
		end)

		resBtn.MouseButton1Click:Connect(function()
			SearchBox.Text = ""
			Tween(SearchResultFrame, { Size = UDim2.new(1, -40, 0, 0) }, 0.18)

			task.spawn(function()
				Tween(SettingsUI, { Position = UDim2.new(1, 0, 0, 0) }, 0.32, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
				task.wait(0.34)
				SettingsUI.Visible = false

				if entry.selectTab then
					entry.selectTab()
				elseif entry.tabBtn and entry.tabBtn.Activated then
					entry.tabBtn:Activate()
				end

				task.wait(0.15)

				if entry.instance and entry.instance.Parent then
					local scrollFrame
					local p = entry.instance

					for _ = 1, 10 do
						p = p.Parent
						if not p then
							break
						end
						if p:IsA("ScrollingFrame") then
							scrollFrame = p
							break
						end
					end

					scrollToInstance(scrollFrame, entry.instance, 40)
					task.wait(0.1)
					flashHighlight(entry.instance)
				end
			end)
		end)
