local function scrollToInstance(scrollFrame, inst, padding)
	if not scrollFrame or not inst or not scrollFrame:IsA("ScrollingFrame") then
		return
	end

	padding = padding or 40

	local targetY = inst.AbsolutePosition.Y - scrollFrame.AbsolutePosition.Y + scrollFrame.CanvasPosition.Y - padding
	local maxY = math.max(0, scrollFrame.AbsoluteCanvasSize.Y - scrollFrame.AbsoluteWindowSize.Y)
	targetY = math.clamp(targetY, 0, maxY)

	TweenService:Create(
		scrollFrame,
		TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
		{ CanvasPosition = Vector2.new(scrollFrame.CanvasPosition.X, targetY) }
	):Play()
end

local function flashHighlight(inst)
	if not inst or not inst.Parent then
		return
	end

	local origBG = inst.BackgroundColor3
	local origBGT = inst.BackgroundTransparency
	local stroke = inst:FindFirstChildOfClass("UIStroke")
	local origStroke = stroke and stroke.Transparency

	for _ = 1, 3 do
		Tween(inst, { BackgroundColor3 = Color3.fromRGB(55, 55, 55), BackgroundTransparency = 0 }, 0.12)
		task.wait(0.18)
		Tween(inst, { BackgroundColor3 = origBG, BackgroundTransparency = origBGT }, 0.12)
		if stroke and origStroke ~= nil then
			Tween(stroke, { Transparency = origStroke }, 0.12)
		end
		task.wait(0.18)
	end
end

local function doSearch(query)
	for _, c in ipairs(SearchResultFrame:GetChildren()) do
		if c:IsA("TextButton") then
			c:Destroy()
		end
	end

	if query == "" then
		Tween(SearchResultFrame, { Size = UDim2.new(1, -40, 0, 0) }, 0.18)
		return
	end

	local results = {}
	local lq = query:lower()

	for _, entry in ipairs(FeatureRegistry) do
		if entry.name:lower():find(lq, 1, true)
			or entry.tabName:lower():find(lq, 1, true)
			or (entry.sectionName and entry.sectionName:lower():find(lq, 1, true)) then
			table.insert(results, entry)
			if #results >= 6 then
				break
			end
		end
	end

	for _, entry in ipairs(results) do
		local resBtn = Instance.new("TextButton")
		resBtn.Parent = SearchResultFrame
		resBtn.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
		resBtn.BackgroundTransparency = 1
