					end
				end
			end
			-- Stagger fade/slide in
			for i, item in ipairs(allItems) do
				local origT = item.BackgroundTransparency
				item.BackgroundTransparency = 1
				item.Position = UDim2.new(0, 0, 0, 0)
				-- slight offset
