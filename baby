				local ItemLabel=Instance.new("TextLabel"); ItemLabel.Parent=item; ItemLabel.BackgroundTransparency=1; ItemLabel.Position=UDim2.new(0,10,0,0)
				ItemLabel.Size=UDim2.new(1,-14,1,0); ItemLabel.Font=Enum.Font.Gotham; ItemLabel.Text=tostring(text)
				ItemLabel.TextColor3=isSelected and TxtPri or TxtMut; ItemLabel.TextSize=11; ItemLabel.TextXAlignment=Enum.TextXAlignment.Left; ItemLabel.ZIndex=18
				local itemSelected=isSelected
				item.MouseEnter:Connect(function() Tween(item,{BackgroundTransparency=0,BackgroundColor3=Color3.fromRGB(18,18,18)},0.12); Tween(ItemLabel,{TextColor3=TxtPri},0.12); Tween(ItemBar,{BackgroundTransparency=0},0.12) end)
				item.MouseLeave:Connect(function()
					if not itemSelected then Tween(item,{BackgroundTransparency=1},0.12); Tween(ItemLabel,{TextColor3=TxtMut},0.12); Tween(ItemBar,{BackgroundTransparency=1},0.12)
					else Tween(item,{BackgroundColor3=Color3.fromRGB(11,11,11),BackgroundTransparency=0},0.12); Tween(ItemLabel,{TextColor3=TxtPri},0.12); Tween(ItemBar,{BackgroundTransparency=0},0.12) end
				end)
				local function setSelected(sel)
					itemSelected=sel
					if sel then Tween(item,{BackgroundTransparency=0,BackgroundColor3=Color3.fromRGB(11,11,11)},0.18); Tween(ItemLabel,{TextColor3=TxtPri},0.18); Tween(ItemBar,{BackgroundTransparency=0},0.18)
					else Tween(item,{BackgroundTransparency=1},0.18); Tween(ItemLabel,{TextColor3=TxtMut},0.18); Tween(ItemBar,{BackgroundTransparency=1},0.18) end
				end
				return item, ItemLabel, ItemBar, setSelected
			end

			function functionitem:Dropdown(DDName, list, default, callback)
				local Dropfunc={}; list=list or {}; callback=callback or function() end
				local selected=(default and table.find(list,default)) and default or nil
				local Frame,HitBtn,DisplayText,Arrow,Scroll,SList,FStroke,DDIcon=buildDropHeader(SectionContainer)
				local function refreshCanvas() Scroll.CanvasSize=UDim2.new(0,0,0,SList.AbsoluteContentSize.Y+10) end
				SList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refreshCanvas)
				local function updateText()
					if selected then DisplayText.Text=DDName.."  ›  "..tostring(selected); DisplayText.TextColor3=TxtPri; Tween(DDIcon,{BackgroundColor3=Accent},0.18)
					else DisplayText.Text=DDName; DisplayText.TextColor3=TxtMut; Tween(DDIcon,{BackgroundColor3=Color3.fromRGB(20,20,20)},0.18) end
					fitText(DisplayText,DisplayText.Text,12,9)
				end
				task.defer(function() updateText(); DisplayText:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateText) end)
				local Tof=false
				function Dropfunc:TogglePanel(state)
					Tof=state and true or false
					TweenService:Create(Frame,TweenInfo.new(0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Size=Tof and UDim2.new(1,0,0,math.clamp(42+SList.AbsoluteContentSize.Y+10,34,225)) or UDim2.new(1,0,0,34)}):Play()
					TweenService:Create(Arrow,TweenInfo.new(0.22,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Rotation=Tof and 180 or 0}):Play()
					Tween(FStroke,{Color=Tof and Color3.fromRGB(48,48,48) or Color3.fromRGB(28,28,28)},0.22); Tween(Arrow,{ImageColor3=Tof and TxtPri or Color3.fromRGB(40,40,40)},0.22); refreshCanvas()
				end
				local function toggle() Dropfunc:TogglePanel(not Tof) end
				Arrow.MouseButton1Click:Connect(toggle); HitBtn.MouseButton1Click:Connect(toggle)
				local itemSetFns={}
				function Dropfunc:Clear() for _,c in next,Scroll:GetChildren() do if c:IsA("TextButton") then c:Destroy() end end table.clear(itemSetFns); selected=nil; updateText(); refreshCanvas() end
				function Dropfunc:Get() return selected end
				function Dropfunc:Set(value,silent)
					if table.find(list,value) then selected=value; updateText(); if not silent then callback(value) end
						for _,fn in pairs(itemSetFns) do fn(false) end; if itemSetFns[value] then itemSetFns[value](true) end end
				end
				function Dropfunc:Add(Text)
					local item,ItemLabel,ItemBar,setFn=makeDropItem(Scroll,Text,selected==Text)
					itemSetFns[Text]=setFn
					item.MouseButton1Click:Connect(function() selected=Text; updateText(); callback(Text); Dropfunc:TogglePanel(false); for key,fn in pairs(itemSetFns) do fn(key==Text) end end)
					refreshCanvas()
				end
				for _,v in next,list do Dropfunc:Add(v) end; updateText(); refreshCanvas()
				if selected then callback(selected) end
				table.insert(FeatureRegistry,{name=tostring(DDName),tabName=Name,sectionName=SectionName,instance=Frame,tabBtn=TabBtn})
				return Dropfunc
			end

			function functionitem:MultiDropdown(MDName, list, default, callback)
				local Dropfunc={}; list=list or {}; callback=callback or function() end; local DropTable={}
				if type(default)=="table" then for _,v in next,default do if table.find(list,v) and not table.find(DropTable,v) then table.insert(DropTable,v) end end end
				local Frame,HitBtn,DisplayText,Arrow,Scroll,SList,FStroke,DDIcon=buildDropHeader(SectionContainer)
				local function refreshCanvas() Scroll.CanvasSize=UDim2.new(0,0,0,SList.AbsoluteContentSize.Y+10) end
				SList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refreshCanvas)
				local function updateText()
					if #DropTable>0 then
						if #DropTable<=3 then DisplayText.Text=MDName.."  ›  "..table.concat(DropTable,", ")
						else DisplayText.Text=MDName.."  ›  "..table.concat({DropTable[1],DropTable[2],DropTable[3]},", ").."  +"..(#DropTable-3) end
						DisplayText.TextColor3=TxtPri; Tween(DDIcon,{BackgroundColor3=Accent},0.18)
					else DisplayText.Text=MDName; DisplayText.TextColor3=TxtMut; Tween(DDIcon,{BackgroundColor3=Color3.fromRGB(20,20,20)},0.18) end
					fitText(DisplayText,DisplayText.Text,12,9)
				end
				task.defer(function() updateText(); DisplayText:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateText) end)
				local Tof=false
				function Dropfunc:TogglePanel(state)
					Tof=state and true or false
					TweenService:Create(Frame,TweenInfo.new(0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Size=Tof and UDim2.new(1,0,0,math.clamp(42+SList.AbsoluteContentSize.Y+10,34,225)) or UDim2.new(1,0,0,34)}):Play()
					TweenService:Create(Arrow,TweenInfo.new(0.22,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),{Rotation=Tof and 180 or 0}):Play()
					Tween(FStroke,{Color=Tof and Color3.fromRGB(48,48,48) or Color3.fromRGB(28,28,28)},0.22); Tween(Arrow,{ImageColor3=Tof and TxtPri or Color3.fromRGB(40,40,40)},0.22); refreshCanvas()
				end
				local function toggle() Dropfunc:TogglePanel(not Tof) end
				Arrow.MouseButton1Click:Connect(toggle); HitBtn.MouseButton1Click:Connect(toggle)
				function Dropfunc:Clear() for _,c in next,Scroll:GetChildren() do if c:IsA("TextButton") then c:Destroy() end end table.clear(DropTable); updateText(); refreshCanvas() end
				function Dropfunc:Get() return DropTable end
				function Dropfunc:Set(values,silent) table.clear(DropTable); if type(values)=="table" then for _,v in next,values do if table.find(list,v) and not table.find(DropTable,v) then table.insert(DropTable,v) end end end; updateText(); if not silent then callback(DropTable) end end
				function Dropfunc:Add(Text)
					local item,ItemLabel,ItemBar,setFn=makeDropItem(Scroll,Text,table.find(DropTable,Text)~=nil)
					local Check=Instance.new("TextLabel"); Check.Name="Check"; Check.Parent=item; Check.BackgroundTransparency=1; Check.Size=UDim2.new(0,18,1,0); Check.Position=UDim2.new(1,-20,0,0)
					Check.Font=Enum.Font.GothamBold; Check.Text="✓"; Check.TextSize=11; Check.TextColor3=Accent; Check.TextTransparency=table.find(DropTable,Text) and 0 or 1; Check.ZIndex=18
					item.MouseButton1Click:Connect(function()
						local found=table.find(DropTable,Text)
						if not found then table.insert(DropTable,Text); Tween(Check,{TextTransparency=0},0.18); setFn(true)
						else table.remove(DropTable,found); Tween(Check,{TextTransparency=1},0.18); setFn(false) end
						updateText(); callback(DropTable,Text)
					end); refreshCanvas()
				end
				for _,v in next,list do Dropfunc:Add(v) end; updateText(); refreshCanvas()
				if #DropTable>0 then callback(DropTable) end
				table.insert(FeatureRegistry,{name=tostring(MDName),tabName=Name,sectionName=SectionName,instance=Frame,tabBtn=TabBtn})
				return Dropfunc
			end

			function functionitem:Slider(text, floor, min, max, de, callback)
				local sliderfunc={}; floor=floor or false; min=min or 0; max=max or 100; de=de or min; callback=callback or function() end
				local SliderFrame=Instance.new("Frame"); SliderFrame.Name="SliderFrame"; SliderFrame.Parent=SectionContainer
				SliderFrame.BackgroundColor3=Color3.fromRGB(18,18,18); SliderFrame.BackgroundTransparency=0; SliderFrame.BorderSizePixel=0; SliderFrame.Size=UDim2.new(1,0,0,52)
				grad(SliderFrame,ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(25,25,25)),ColorSequenceKeypoint.new(1,Color3.fromRGB(13,13,13))}),90)
				local SFCorner=Instance.new("UICorner"); SFCorner.CornerRadius=UDim.new(0,8); SFCorner.Parent=SliderFrame
				local SFStroke=Instance.new("UIStroke"); SFStroke.Color=Border; SFStroke.Thickness=1; SFStroke.Parent=SliderFrame
				local LabelNameSlider=Instance.new("TextLabel"); LabelNameSlider.Parent=SliderFrame; LabelNameSlider.BackgroundTransparency=1
				LabelNameSlider.Position=UDim2.new(0,13,0,10); LabelNameSlider.Size=UDim2.new(0.65,0,0,12)
				LabelNameSlider.Font=Enum.Font.Gotham; LabelNameSlider.Text=tostring(text); LabelNameSlider.TextColor3=TxtMut; LabelNameSlider.TextSize=10; LabelNameSlider.TextXAlignment=Enum.TextXAlignment.Left
				local ShowValueFrame=Instance.new("Frame"); ShowValueFrame.Parent=SliderFrame; ShowValueFrame.BackgroundColor3=BG; ShowValueFrame.BorderSizePixel=0
				ShowValueFrame.Position=UDim2.new(1,-52,0,9); ShowValueFrame.Size=UDim2.new(0,44,0,14)
				local SVC=Instance.new("UICorner"); SVC.CornerRadius=UDim.new(0,5); SVC.Parent=ShowValueFrame
				local SVCStroke=Instance.new("UIStroke"); SVCStroke.Color=Color3.fromRGB(24,24,24); SVCStroke.Thickness=1; SVCStroke.Parent=ShowValueFrame
				local CustomValue=Instance.new("TextBox"); CustomValue.Parent=ShowValueFrame; CustomValue.BackgroundTransparency=1
				CustomValue.Size=UDim2.new(1,0,1,0); CustomValue.Font=Enum.Font.GothamBold; CustomValue.Text=tostring(de); CustomValue.TextColor3=TxtPri; CustomValue.TextSize=10
				local ValueFrame=Instance.new("Frame"); ValueFrame.Parent=SliderFrame; ValueFrame.BackgroundColor3=Color3.fromRGB(20,20,20); ValueFrame.BorderSizePixel=0
				ValueFrame.Position=UDim2.new(0,13,0,37); ValueFrame.Size=UDim2.new(1,-26,0,5)
				local VC=Instance.new("UICorner"); VC.CornerRadius=UDim.new(1,0); VC.Parent=ValueFrame
				local MainValue=Instance.new("Frame"); MainValue.Parent=ValueFrame; MainValue.BackgroundColor3=Accent; MainValue.BorderSizePixel=0; MainValue.Size=UDim2.new(0,0,1,0)
				local MVC=Instance.new("UICorner"); MVC.CornerRadius=UDim.new(1,0); MVC.Parent=MainValue
				grad(MainValue,ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(45,45,45)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(160,160,160)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,255,255))}),0)
				local Knob=Instance.new("Frame"); Knob.Parent=MainValue; Knob.AnchorPoint=Vector2.new(1,0.5); Knob.BackgroundColor3=Color3.fromRGB(235,235,235)
				Knob.BorderSizePixel=0; Knob.Position=UDim2.new(1,0,0.5,0); Knob.Size=UDim2.new(0,11,0,11)
				local KC=Instance.new("UICorner"); KC.CornerRadius=UDim.new(1,0); KC.Parent=Knob
				local KStroke=Instance.new("UIStroke"); KStroke.Color=Color3.fromRGB(50,50,50); KStroke.Thickness=1.5; KStroke.Parent=Knob
				local function formatValue(val) return floor and tostring(math.floor(val+0.5)) or tostring(math.floor(val)) end
				local function updateVisual(value)
					local scale=(math.clamp(value,min,max)-min)/(max-min)
					MainValue:TweenSize(UDim2.new(scale,0,1,0),Enum.EasingDirection.Out,Enum.EasingStyle.Quart,0.12,true)
				end
				CustomValue.Text=formatValue(de); updateVisual(de)
				local dragging=false
				local function move(input)
					local pos=math.clamp((input.Position.X-ValueFrame.AbsolutePosition.X)/ValueFrame.AbsoluteSize.X,0,1)
					local value=min+(max-min)*pos; CustomValue.Text=formatValue(value); updateVisual(value); callback(math.clamp(value,min,max))
				end
				Knob.InputBegan:Connect(function(input)
					if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; Tween(SFStroke,{Color=Color3.fromRGB(62,62,62)},0.16); Tween(Knob,{Size=UDim2.new(0,14,0,14)},0.14) end
				end)
				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false; Tween(SFStroke,{Color=Border},0.16); Tween(Knob,{Size=UDim2.new(0,11,0,11)},0.14) end
				end)
				UserInputService.InputChanged:Connect(function(input)
					if dragging and input.UserInputType==Enum.UserInputType.MouseMovement then move(input) end
				end)
				ValueFrame.InputBegan:Connect(function(input)
					if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; move(input); Tween(SFStroke,{Color=Color3.fromRGB(62,62,62)},0.16) end
				end)
				CustomValue.FocusLost:Connect(function()
					local num=math.clamp(tonumber(CustomValue.Text) or de,min,max); CustomValue.Text=formatValue(num); updateVisual(num); callback(num)
				end)
				function sliderfunc:Set(v) v=math.clamp(v,min,max); CustomValue.Text=formatValue(v); updateVisual(v); callback(v) end
				table.insert(FeatureRegistry,{name=tostring(text),tabName=Name,sectionName=SectionName,instance=SliderFrame,tabBtn=TabBtn})
				return sliderfunc
			end

			return functionitem
		end

		return sections
	end

