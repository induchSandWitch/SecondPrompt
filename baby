	-- ── Easing presets ──────────────────────────────────────────────────────
	local function Tween(obj, props, dur, style, dir)
		if not obj or not obj.Parent then return end
		local t = TweenService:Create(
			obj,
			TweenInfo.new(dur or 0.28, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
			props
		)
		t:Play(); return t
	end

	local function resolveColor(c)
		if typeof(c) == "Color3"   then return c
		elseif type(c) == "number" then return Color3.fromRGB(c, c, c)
		else                            return Color3.fromRGB(255, 255, 255) end
	end

	local function fitText(label, text, maxSize, minSize)
		text = tostring(text or "")
		maxSize = maxSize or 13; minSize = minSize or 9
		label.Text = text
		local width = math.max(1, label.AbsoluteSize.X)
		local chosen = minSize
		for size = maxSize, minSize, -1 do
			local b = TextService:GetTextSize(text, size, label.Font, Vector2.new(10000, 1000))
			if b.X <= width then chosen = size; break end
		end
		label.TextSize = chosen
	end

	local function grad(parent, seq, rot)
		local g = Instance.new("UIGradient")
		g.Color    = seq or ColorSequence.new(Color3.fromRGB(20,20,20), Color3.fromRGB(8,8,8))
		g.Rotation = rot or 90
		g.Parent   = parent
		return g
	end

	local function fadeCenter(parent, mid, rot)
		local k0 = Color3.fromRGB(8, 8, 8)
		local km  = mid or Color3.fromRGB(50, 50, 50)
		grad(parent, ColorSequence.new({
			ColorSequenceKeypoint.new(0,    k0),
			ColorSequenceKeypoint.new(0.35, km),
			ColorSequenceKeypoint.new(0.65, km),
			ColorSequenceKeypoint.new(1,    k0),
		}), rot or 0)
	end

	-- ── Shimmer animations ──────────────────────────────────────────────────
	local function startShimmerAnimation(gradObj, speed, minBright, maxBright)
		speed     = speed     or 1.2
		minBright = minBright or 0.10
		maxBright = maxBright or 1.00
		local t = 0
		local conn
		conn = RunService.Heartbeat:Connect(function(dt)
			t = (t + dt * speed) % 1
			local sweep  = math.abs(math.sin(t * math.pi * 2))
			local center = minBright + (maxBright - minBright) * sweep
			local edge   = minBright
			local c_center = Color3.fromRGB(math.floor(255*center), math.floor(255*center), math.floor(255*center))
			local c_edge   = Color3.fromRGB(math.floor(255*edge),   math.floor(255*edge),   math.floor(255*edge))
			local ok = pcall(function()
				gradObj.Color = ColorSequence.new({
					ColorSequenceKeypoint.new(0,    c_edge),
					ColorSequenceKeypoint.new(0.38, c_center),
					ColorSequenceKeypoint.new(0.62, c_center),
					ColorSequenceKeypoint.new(1,    c_edge),
				})
			end)
			if not ok then conn:Disconnect() end
		end)
		table.insert(shimmerConnections, conn)
		return conn
	end

	-- ── Dragify ──────────────────────────────────────────────────────────────
	local function dragify(handle, frame)
		local dragging, dragInput, mousePos, framePos
		handle.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging  = true
				mousePos  = input.Position
				framePos  = frame.Position
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then dragging = false end
				end)
			end
		end)
		handle.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				dragInput = input
			end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if input == dragInput and dragging then
				local delta = input.Position - mousePos
				frame.Position = UDim2.new(
					framePos.X.Scale, framePos.X.Offset + delta.X,
					framePos.Y.Scale, framePos.Y.Offset + delta.Y
				)
			end
		end)
	end

