		resBtn.Text = ""
		resBtn.ZIndex = 601

		local rBtnC = Instance.new("UICorner")
		rBtnC.CornerRadius = UDim.new(0, 6)
		rBtnC.Parent = resBtn

		local rName = Instance.new("TextLabel")
		rName.Parent = resBtn
		rName.BackgroundTransparency = 1
		rName.Position = UDim2.new(0, 8, 0, 0)
		rName.Size = UDim2.new(0.6, 0, 1, 0)
		rName.Font = Enum.Font.GothamBold
