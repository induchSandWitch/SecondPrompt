	-- RUN INTRO ANIMATION
	-- ═══════════════════════════════════════════════════════════════════════
	Main.Visible = false
	Main.Size = UDim2.new(0, 0, 0, 0)
	Main.BackgroundTransparency = 0

	task.spawn(function()
		task.wait(0.2)

		-- PHASE 1: Insane elastic pop-in
		TweenService:Create(IntroCard, TweenInfo.new(0.9, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, 260, 0, 120)
		}):Play()
		TweenService:Create(IntroCardStroke, TweenInfo.new(0.3), {Transparency = 0}):Play()
		TweenService:Create(IntroTitle, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			TextTransparency = 0
		}):Play()

		task.wait(0.6)

		-- PHASE 2: Glitch shake
		local duration = 0.7
		local start = tick()
		while tick() - start < duration do
			local t = (tick() - start) / duration
			local intensity = (1 - t)
			local ox = (math.random() - 0.5) * 14 * intensity
			local oy = (math.random() - 0.5) * 10 * intensity
			IntroTitle.Position = UDim2.new(0.5, ox, 0.5, oy)
			GlitchR.Position = UDim2.new(0.5, ox - 5 * intensity, 0.5, oy)
			GlitchB.Position = UDim2.new(0.5, ox + 5 * intensity, 0.5, oy)
			GlitchR.TextTransparency = 0.6 * intensity
			GlitchB.TextTransparency = 0.6 * intensity
			task.wait(0.025)
		end
		IntroTitle.Position = UDim2.new(0.5, 0, 0.5, 0)
		GlitchR.TextTransparency = 1
		GlitchB.TextTransparency = 1

		task.wait(0.15)

		-- PHASE 3: Morph into Main UI size
		local targetSize = UDim2.new(0, 640, 0, 450)
		local s = workspace.CurrentCamera.ViewportSize
		local w, h = s.X, s.Y
		if _G.UISize == "Auto" then
			if     w <= 600  or h <= 400 then targetSize = UDim2.new(0, 480, 0, 320)
			elseif w <= 800  or h <= 600 then targetSize = UDim2.new(0, 520, 0, 360)
			elseif w <= 1100 or h <= 700 then targetSize = UDim2.new(0, 580, 0, 400)
			elseif w <= 1400 or h <= 900 then targetSize = UDim2.new(0, 640, 0, 450)
			else                              targetSize = UDim2.new(0, 720, 0, 500) end
		elseif _G.UISize == "Large"  then targetSize = UDim2.new(0, 720, 0, 500)
		elseif _G.UISize == "Big"    then targetSize = UDim2.new(0, 640, 0, 450)
		elseif _G.UISize == "Normal" then targetSize = UDim2.new(0, 520, 0, 360) end

		-- Circle corners morph into Main window corners
		TweenService:Create(IntroCardCorner, TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			CornerRadius = UDim.new(0, 16)
		}):Play()

		-- Card grows to full window size
		TweenService:Create(IntroCard, TweenInfo.new(0.65, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = targetSize
		}):Play()

		-- "NaJa" slides up and shrinks to become the title bar text
		TweenService:Create(IntroTitle, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, 16, 0, 8),
			AnchorPoint = Vector2.new(0, 0),
			TextSize = 14
		}):Play()

		TweenService:Create(IntroCardStroke, TweenInfo.new(0.4), {Transparency = 1}):Play()

		task.wait(0.55)

		-- PHASE 4: White flash — the card BECOMES the Main UI
		TweenService:Create(FlashFrame, TweenInfo.new(0.06), {BackgroundTransparency = 0}):Play()
		task.wait(0.06)

		IntroOverlay.Visible = false
		Main.Visible = true
		Main.Size = targetSize
		Main.Position = UDim2.new(0.5, 0, 0.5, 0)

		TweenService:Create(FlashFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			BackgroundTransparency = 1
		}):Play()
	end)

